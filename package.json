{
  "name": "gacli",
  "version": "1.0.0",
  "description": "Full-featured Google Analytics 4 CLI tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gacli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@google-analytics/admin": "^5.0.0",
    "@google-analytics/data": "^4.8.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "google-auth-library": "^9.14.0",
    "ora": "^8.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
